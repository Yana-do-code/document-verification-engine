APP_ENV=development

UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=5
IMAGE_MAX_WIDTH=1600

OCR_LANG=en
LOG_LEVEL=INFO

# CORS — set to your Vercel URL in production, keep * for local dev
CORS_ORIGINS=*

# MongoDB — use Docker URI locally, Atlas URI in production
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=doc_verification
